{
  "name": "@mdxforge/ui",
  "version": "1.0.0",
  "private": true,
  "description": "Shared React UI primitives for MDXForge apps",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "pnpm run typecheck"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@tabler/icons-react": "^3.36.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.71.1",
    "react-resizable-panels": "^4.6.4",
    "recharts": "3.8.0",
    "tailwind-merge": "^3.0.2",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "shadcn": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
