{
  "name": "@mdxforge/ui",
  "version": "1.0.0",
  "private": true,
  "description": "Shared React UI primitives for MDXForge apps",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "pnpm run typecheck"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "dependencies": {
    "@base-ui/react": "catalog:ui",
    "@tabler/icons-react": "catalog:",
    "class-variance-authority": "catalog:ui",
    "clsx": "catalog:ui",
    "cmdk": "catalog:ui",
    "embla-carousel-react": "catalog:ui",
    "react-day-picker": "catalog:ui",
    "react-hook-form": "catalog:ui",
    "react-resizable-panels": "catalog:ui",
    "recharts": "catalog:",
    "tailwind-merge": "catalog:ui",
    "vaul": "catalog:ui"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "^4.0.0",
    "typescript": "catalog:"
  }
}
