{
  "name": "@mdxforge/mdx",
  "version": "0.1.5",
  "private": true,
  "description": "Shared MDX/Fumadocs configuration for MDXForge apps",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mdx-options": {
      "types": "./dist/mdx-options.d.ts",
      "default": "./dist/mdx-options.js"
    }
  },
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "fumadocs-core": "^16.9.0",
    "fumadocs-twoslash": "^3.2.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "typescript": "catalog:"
  }
}
