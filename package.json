{
  "name": "mdxforge",
  "version": "1.0.0",
  "description": "AI-native MDX docs workspace",
  "main": "./out/main/index.js",
  "author": "MDXForge",
  "homepage": "https://github.com/tszones/MDXforge",
  "bin": {
    "mdxforge": "bin/mdxforge.cjs",
    "df": "bin/mdxforge.cjs"
  },
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/renderer/src/paraglide --strategy localStorage preferredLanguage baseLocale --emit-ts-declarations --output-structure locale-modules --silent",
    "typecheck:web": "npm run paraglide:compile && tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test:main-bundle-boundary": "node scripts/test-main-bundle-boundary.cjs",
    "test:renderer-boundary": "node scripts/test-renderer-boundary.cjs",
    "test:page-tree": "node scripts/test-page-tree.cjs",
    "test:fixtures": "node scripts/render-mdx-fixtures.cjs",
    "build:icons": "node scripts/generate-linux-icons.cjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "npm run build:icons && electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@react-router/dev": "^7.15.1",
    "@tailwindcss/vite": "^4.3.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "fumadocs-core": "^16.9.0",
    "fumadocs-mdx": "^15.0.7",
    "fumadocs-twoslash": "^3.2.0",
    "fumadocs-ui": "^16.9.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router": "^7.15.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.3.0",
    "twoslash": "^0.3.8",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@inlang/paraglide-js": "^2.18.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "jiti": "^2.7.0",
    "vite": "^7.2.6",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "volta": {
    "node": "24.15.0",
    "pnpm": "10.32.1"
  }
}
