{
  "name": "mdxforge",
  "version": "0.1.7",
  "private": true,
  "description": "MDXForge monorepo",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev --filter=@mdxforge/desktop",
    "start": "turbo run start --filter=@mdxforge/desktop",
    "build": "turbo run build",
    "build:desktop": "turbo run build --filter=@mdxforge/desktop",
    "build:unpack": "turbo run build:unpack --filter=@mdxforge/desktop",
    "build:win": "turbo run build:win --filter=@mdxforge/desktop",
    "build:win64": "turbo run build:win64 --filter=@mdxforge/desktop",
    "build:mac": "turbo run build:mac --filter=@mdxforge/desktop",
    "build:linux": "turbo run build:linux --filter=@mdxforge/desktop",
    "build:icons": "turbo run build:icons --filter=@mdxforge/desktop",
    "typecheck": "turbo run typecheck",
    "typecheck:node": "turbo run typecheck:node",
    "typecheck:web": "turbo run typecheck:web",
    "paraglide:compile": "turbo run paraglide:compile",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "test": "turbo run test",
    "test:boundaries": "node scripts/check-boundaries.cjs",
    "test:file-lines": "node scripts/check-file-lines.cjs",
    "test:main-bundle-boundary": "turbo run test:main-bundle-boundary --filter=@mdxforge/desktop",
    "test:renderer-boundary": "turbo run test:renderer-boundary --filter=@mdxforge/desktop",
    "test:local-images": "turbo run test:local-images --filter=@mdxforge/desktop",
    "test:page-tree": "turbo run test:page-tree --filter=@mdxforge/desktop",
    "test:mdx-raw-source": "turbo run test:mdx-raw-source --filter=@mdxforge/desktop",
    "test:search": "turbo run test:search --filter=@mdxforge/desktop",
    "test:extensions": "turbo run test:extensions --filter=@mdxforge/desktop",
    "test:fixtures": "turbo run test:fixtures --filter=@mdxforge/desktop",
    "dev:web": "turbo run dev --filter=@mdxforge/web",
    "start:web": "turbo run start --filter=@mdxforge/web",
    "build:web": "turbo run build --filter=@mdxforge/web",
    "deploy:web": "turbo run deploy --filter=@mdxforge/web",
    "cf-typegen:web": "turbo run cf-typegen --filter=@mdxforge/web"
  },
  "devDependencies": {
    "electron": "catalog:electron",
    "turbo": "^2.9.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "volta": {
    "node": "24.15.0",
    "pnpm": "10.32.1"
  }
}
