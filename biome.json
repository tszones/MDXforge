{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "apps/desktop/src/**",
      "apps/desktop/scripts/**",
      "apps/desktop/content/**",
      "apps/desktop/messages/**",
      "apps/desktop/*.ts",
      "apps/desktop/*.js",
      "apps/desktop/*.cjs",
      "apps/desktop/*.mjs",
      "apps/desktop/*.json",
      "apps/desktop/*.jsonc",
      "apps/desktop/*.md",
      "apps/desktop/*.mdx",
      "apps/desktop/*.yaml",
      "apps/desktop/*.yml",
      "docs/**",
      "skills/**",
      "*.ts",
      "*.js",
      "*.cjs",
      "*.mjs",
      "*.json",
      "*.jsonc",
      "*.md",
      "*.mdx",
      "*.yaml",
      "*.yml",
      "!**/pnpm-lock.yaml",
      "!**/tsconfig*.json",
      "!**/*.tsbuildinfo",
      "!**/dist",
      "!**/out",
      "!**/build",
      "!**/node_modules",
      "!apps/desktop/src/renderer/src/paraglide",
      "!apps/desktop/src/renderer/src/components/ui",
      "!apps/desktop/src/renderer/src/assets",
      "!apps/desktop/test-fixtures",
      "!apps/desktop/project.inlang"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "useLiteralKeys": "off",
        "noUselessStringRaw": "off"
      },
      "correctness": {
        "useHookAtTopLevel": "off",
        "noUnusedVariables": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "off"
      },
      "suspicious": {
        "noExplicitAny": "off"
      },
      "a11y": {
        "useHtmlLang": "off"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "none"
    }
  }
}
