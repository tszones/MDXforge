{
  "name": "@mdxforge/desktop",
  "version": "0.1.3",
  "description": "AI-native MDX docs workspace",
  "main": "./out/main/index.js",
  "author": "MDXForge",
  "license": "MIT",
  "homepage": "https://github.com/tszones/MDXforge",
  "bin": {
    "mdxforge": "bin/mdxforge.cjs",
    "df": "bin/mdxforge.cjs"
  },
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/renderer/src/paraglide --strategy localStorage preferredLanguage baseLocale --emit-ts-declarations --output-structure locale-modules --silent",
    "typecheck:web": "pnpm run paraglide:compile && tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "test": "pnpm run test:renderer-boundary && pnpm run test:local-images && pnpm run test:page-tree && pnpm run test:mdx-raw-source && pnpm run test:search && pnpm run test:extensions && pnpm run test:fixtures",
    "test:main-bundle-boundary": "node scripts/test-main-bundle-boundary.cjs",
    "test:renderer-boundary": "node scripts/test-renderer-boundary.cjs",
    "test:local-images": "node scripts/test-local-images.cjs",
    "test:page-tree": "node scripts/test-page-tree.cjs",
    "test:mdx-raw-source": "node scripts/test-mdx-raw-source.cjs",
    "test:search": "node scripts/test-search.cjs",
    "test:skills": "node scripts/test-skills.cjs",
    "test:extensions": "node scripts/test-extensions.cjs",
    "test:fixtures": "node scripts/render-mdx-fixtures.cjs",
    "build:icons": "node scripts/generate-linux-icons.cjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run build && node scripts/clean-dist.cjs && electron-builder --dir",
    "build:win": "pnpm run build && node scripts/clean-dist.cjs && electron-builder --win",
    "build:win64": "pnpm run build && node scripts/clean-dist.cjs && electron-builder --win --x64",
    "build:mac": "pnpm run build && node scripts/clean-dist.cjs && electron-builder --mac",
    "build:linux": "pnpm run build && node scripts/clean-dist.cjs && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/bricolage-grotesque": "^5.2.10",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@mdxforge/mdx": "workspace:*",
    "@mdxforge/mdx-components": "workspace:*",
    "@mdxforge/ui": "workspace:*",
    "@react-router/dev": "^7.15.1",
    "@tabler/icons-react": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@typescript/vfs": "^1.6.4",
    "date-fns": "^4.1.0",
    "debug": "^4.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "fumadocs-core": "^16.9.0",
    "fumadocs-mdx": "^15.0.7",
    "fumadocs-twoslash": "^3.2.0",
    "fumadocs-ui": "^16.9.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "ms": "^2.1.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "^7.15.1",
    "recharts": "catalog:",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "twoslash": "^0.3.8",
    "twoslash-protocol": "0.3.8",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@inlang/paraglide-js": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "electron": "catalog:electron",
    "electron-builder": "catalog:electron",
    "electron-vite": "catalog:electron",
    "jiti": "^2.7.0",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  },
  "private": true
}
