{
  "name": "@mdxforge/web",
  "version": "1.0.0",
  "private": true,
  "description": "MDXForge marketing website",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000 --host 0.0.0.0",
    "start": "vite preview --port 3000 --host 0.0.0.0",
    "build": "vite build",
    "paraglide:compile": "node ./scripts/compile-paraglide.mjs",
    "typecheck": "pnpm run paraglide:compile && tsc --noEmit -p tsconfig.json",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "deploy": "wrangler deploy",
    "cf-typegen": "pnpm run paraglide:compile && wrangler types --env-interface Env"
  },
  "dependencies": {
    "@mdxforge/ui": "workspace:*",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-router": "1.159.5",
    "@tanstack/react-start": "1.159.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/vite-plugin": "^1.13.8",
    "@inlang/paraglide-js": "^2.18.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-tsconfig-paths": "^6.1.1",
    "wrangler": "^4.84.1"
  }
}
