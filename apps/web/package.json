{
  "name": "@mdxforge/web",
  "version": "0.1.6",
  "private": true,
  "description": "MDXForge marketing website",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000 --host 0.0.0.0",
    "start": "vite preview --port 3000 --host 0.0.0.0",
    "build": "pnpm run paraglide:compile && vite build",
    "paraglide:compile": "node ./scripts/compile-paraglide.mjs",
    "typecheck": "pnpm run paraglide:compile && tsc --noEmit -p tsconfig.json",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "deploy": "wrangler deploy",
    "cf-typegen": "pnpm run paraglide:compile && wrangler types --env-interface Env"
  },
  "dependencies": {
    "@mdxforge/mdx": "workspace:*",
    "@mdxforge/mdx-components": "workspace:*",
    "@mdxforge/ui": "workspace:*",
    "@react-email/components": "catalog:email",
    "@tabler/icons-react": "catalog:",
    "@tanstack/react-router": "catalog:tanstack",
    "@tanstack/react-start": "catalog:tanstack",
    "fumadocs-core": "^16.9.0",
    "fumadocs-mdx": "^15.0.7",
    "fumadocs-ui": "^16.9.0",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "resend": "catalog:email",
    "twoslash": "^0.3.8",
    "twoslash-protocol": "0.3.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@cloudflare/vite-plugin": "catalog:cloudflare",
    "@inlang/paraglide-js": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "wrangler": "catalog:cloudflare"
  }
}
