{
  "schema": 1,
  "name": "mdxforge-mdx",
  "title": "MDXForge MDX Writing",
  "version": "0.1.0",
  "description": "Official authoring rules for MDXForge-compatible MDX documents.",
  "types": ["writing"],
  "rules": [
    "./SKILL.md",
    "./patterns/document-structure.md",
    "./checklists/preflight.md",
    "./components/callout.md",
    "./components/cards.md",
    "./components/steps.md",
    "./components/tabs.md",
    "./components/files.md",
    "./components/mermaid.md",
    "./components/charts.md",
    "./components/todo.md",
    "./components/accordion.md",
    "./components/code.md",
    "./components/github-info.md",
    "./components/images.md",
    "./components/inline-toc.md",
    "./components/tables.md"
  ],
  "components": [
    "Accordion",
    "Accordions",
    "Banner",
    "Callout",
    "Card",
    "Cards",
    "DynamicCodeBlock",
    "File",
    "Files",
    "Folder",
    "GithubInfo",
    "ImageZoom",
    "InlineTOC",
    "Mermaid",
    "MetricCard",
    "SimpleBarChart",
    "SimpleLineChart",
    "StatGrid",
    "Step",
    "Steps",
    "Tab",
    "Tabs",
    "TabsContent",
    "TabsList",
    "TabsTrigger",
    "ToDo",
    "ToDoList",
    "Todo",
    "TodoList",
    "TypeTable"
  ],
  "agentAdapters": ["claude-code", "cursor", "codex", "aider"]
}
